[global]
font = 0xProto Nerd Font Mono 12
icon_theme = "Vortex-Dark-Icons"
enable_recursive_icon_lookup = true
markup = full
format = "<b>%s</b>\n%b"
corner_radius = 8
sort = no
indicate_hidden = yes
alignment = left
show_age_threshold = 60
word_wrap = yes
ignore_newline = no
stack_duplicates = true
hide_duplicate_count = yes
origin = top-right
offset = 20x50
width = (0,400)
shrink = no
idle_threshold = 120
follow = none
mouse_left_click = do_action
mouse_right_click = close_all
sticky_history = yes
history_length = 10
show_indicators = no
line_height = 4
separator_height = 4
padding = 15
horizontal_padding = 15
separator_color = auto
startup_notification = true
browser = x-www-browser -new-tab
always_run_script = true
title = Dunst
class = Dunst
icon_position = left
max_icon_size = 48
frame_width = 0

[shortcuts]
close = ctrl+shift+space
close_all = ctrl+shift+space
history = ctrl+grave
context = ctrl+shift+period

[urgency_low]
frame_color = "#4E2A74"
foreground = "#4E2A74"
background = "#07060e"
timeout = 10

[urgency_normal]
frame_color = "#5A4B6F"
foreground = "#5A4B6F"
background = "#07060e"
timeout = 10

[urgency_critical]
frame_color = "#4E2A74"
foreground = "#07060e"
background = "#4E2A74"
timeout = 10

[notify_send]
appname = notify-send
new_icon = bell

[wireless]
appname = wireless
new_icon = network-card
format = "<span font_desc='0xProto Nerd Font Mono'>%b</span>"
