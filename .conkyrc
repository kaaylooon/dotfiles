inclua ram usage

short_units yes
out_to_console no

# Fonte e Xft
use_xft yes
xftfont DejaVu Sans:bold:size=30

# Janela própria transparente
own_window_type override
own_window_transparent true
own_window_argb_visual true
own_window_argb_value 165

# Transparência do texto
xftalpha 0.6

# Atualização em segundos
update_interval 1
double_buffer yes

# Bordas e cores
draw_borders no
draw_shades no
draw_outline no
stippled_borders 0
border_margin 5
border_inner_margin 0
border_width 0.2
xinerama_head 1

default_color a9b1d6

color1 fff   # primary
color2 999   # disabled / separador
color3 999   # foreground

# Alinhamento e posição
alignment top_right
gap_x 800
gap_y 220

# Monitor específico
xinerama_head 1

# Minimiza espaços extras
no_buffers yes

TEXT

${font 0xProto Nerd Font Mono:bold:size=20}${color2}${time %d/%m, %a}
${font DejaVu Sans Mono:bold:size=40}${color1}${time %H:%M:%S}
${font DejaVu Sans Mono:bold:size=20}${color1}Cometer o máximo de erros
AGORA, para 0 erros depois.

${font DejaVu Sans Mono:bold:size=20}${color2}${mem} // ${memmax}

