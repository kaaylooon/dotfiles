#!/bin/bash
# wall-changer-backend - Aplica wallpaper e gera temas completos

IMAGE="$1"

if [ ! -f "$IMAGE" ]; then
    echo "Erro: Arquivo não encontrado: $IMAGE"
    exit 1
fi

# Cria templates completos
mkdir -p ~/.config/wal/templates

# Template Dunst completo
cat > ~/.config/wal/templates/colors-dunst << 'EOF'
[global]
font = 0xProto Nerd Font Mono 11
icon_theme = "Vortex-Dark-Icons"
enable_recursive_icon_lookup = true
markup = full
format = "<b>%s</b>\n%b"
corner_radius = 8
sort = no
indicate_hidden = yes
alignment = left
show_age_threshold = 60
word_wrap = yes
ignore_newline = no
stack_duplicates = true
hide_duplicate_count = yes
origin = top-right
offset = 10x56
width = (0,400)
shrink = no
idle_threshold = 120
follow = none
mouse_left_click = do_action
mouse_right_click = close_all
sticky_history = yes
history_length = 10
show_indicators = no
line_height = 4
separator_height = 4
padding = 15
horizontal_padding = 15
separator_color = auto
startup_notification = true
browser = x-www-browser -new-tab
always_run_script = true
title = Dunst
class = Dunst
icon_position = left
max_icon_size = 48
frame_width = 0

[shortcuts]
close = ctrl+shift+space
close_all = ctrl+shift+space
history = ctrl+grave
context = ctrl+shift+period

[urgency_low]
frame_color = "{color1}"
foreground = "{color1}"
background = "{background}"
timeout = 10

[urgency_normal]
frame_color = "{color2}"
foreground = "{color2}"
background = "{background}"
timeout = 10

[urgency_critical]
frame_color = "{color1}"
foreground = "{background}"
background = "{color1}"
timeout = 10

[notify_send]
appname = notify-send
new_icon = bell

[wireless]
appname = wireless
new_icon = network-card
format = "<span font_desc='0xProto Nerd Font Mono'>%b</span>"
EOF

# Template Rofi
cat > ~/.config/wal/templates/colors-rofi << 'EOF'
* {
    background:     {background}D9;
    background-alt: {color0}E6;
    foreground:     {foreground}FF;
    selected:       {color2}FF;
    active:         {color1}FF;
    urgent:         {color1}FF;
}
EOF

# Template Polybar
cat > ~/.config/wal/templates/colors-polybar << 'EOF'
[colors]
background      = "{background}"
background-alt  = "{color0}"
foreground      = "{foreground}"
primary         = "{color2}"
secondary       = "{color1}"
alert           = "{color1}"
disabled        = "{color8}"
EOF

# Template Kitty
cat > ~/.config/wal/templates/colors-kitty << 'EOF'
# Kitty color scheme generated by Pywal
foreground {foreground}
background {background}
selection_background {color2}
selection_foreground {background}
cursor {foreground}
cursor_text_color background

# Black
color0 {color0}
color8 {color8}

# Red
color1 {color1}
color9 {color9}

# Green
color2 {color2}
color10 {color10}

# Yellow
color3 {color3}
color11 {color11}

# Blue
color4 {color4}
color12 {color12}

# Magenta
color5 {color5}
color13 {color13}

# Cyan
color6 {color6}
color14 {color14}

# White
color7 {color7}
color15 {color15}

# Tabs
active_tab_background {background}
active_tab_foreground {foreground}
inactive_tab_background {color0}
inactive_tab_foreground {color8}
EOF

cat > ~/.config/wal/templates/colors-icewm << 'EOF'
# IceWM Theme Generated by Pywal
ThemeDescription="Dynamic Theme - {wallpaper}"
ThemeAuthor="Pywal"

TitleBarHeight=19
TitleBarJustify=50

TitleButtonsLeft="s"
TitleButtonsRight="xmi"
TitleButtonsSupported="sxmi"

BorderSizeX=6
BorderSizeY=6
CornerSizeX=16
CornerSizeY=16
DlgBorderSizeX=2
DlgBorderSizeY=2

# Border colors
ColorNormalBorder="{color0}"
ColorActiveBorder="{color2}"

# Titlebar
ColorActiveTitleBar="{background}"
ColorNormalTitleBar="{background}"
ColorActiveTitleBarText="{foreground}"
ColorNormalTitleBarText="{foreground}"

# Buttons
ColorNormalButton="{background}"

# Menu
ColorNormalMenu="{background}"
ColorActiveMenuItem="{color2}"
ColorNormalMenuItemText="{foreground}"
ColorActiveMenuItemText="{background}"
ColorDisabledMenuItemText="{color8}"

# Status
ColorMoveSizeStatus="{color2}"
ColorMoveSizeStatusText="{background}"

# Selection
ColorInputSelection="{color2}"

# Taskbar
ColorDefaultTaskBar="{background}"
ColorNormalTaskBarApp="{background}"
ColorNormalTaskBarAppText="{foreground}"
ColorActiveTaskBarApp="{color2}"
ColorActiveTaskBarAppText="{background}"
ColorMinimizedTaskBarApp="{color0}"
ColorMinimizedTaskBarAppText="{color8}"

# Listbox
ColorListBox="{background}"
ColorListBoxText="{foreground}"
ColorListBoxSelection="{color2}"
ColorListBoxSelectionText="{background}"

# Dialog
ColorDialog="{background}"

# Tooltip
ColorToolTip="{color0}"
ColorToolTipText="{foreground}"

# Scrollbar
ColorScrollBar="{color0}"
ColorScrollBarSlider="{color2}"
ColorScrollBarButtonArrow="{foreground}"

# Quick Switch
ColorQuickSwitch="{background}"
ColorQuickSwitchActive="{color2}"
ColorQuickSwitchText="{foreground}"

# Clock
ColorClock="{background}"
ColorClockText="{foreground}"

RolloverButtonsSupported=1

# Background
DesktopBackgroundCenter=0
DesktopBackgroundScaled=1
DesktopBackgroundImage="{wallpaper}"
EOF

cat > ~/.config/wal/templates/colors-btop << 'EOF'
{
  "theme": {
    "main_bg": "{background}",
    "main_fg": "{foreground}",
    "title": "{color2}",
    "error": "{color1}",
    "warning": "{color3}",
    "info": "{color4}",
    "highlight": "{color2}",
    "selected_bg": "{color2}",
    "selected_fg": "{background}",
    "graph_text": "{foreground}",
    "meter_bg": "{color0}",
    "proc_misc": "{color8}",
    "cpu_box": "{color0}",
    "mem_box": "{color0}",
    "net_box": "{color0}",
    "proc_box": "{color0}",
    "divider": "{color8}",
    "divider_light": "{color7}",
    "graph_symbols": "braille",
    "graph_colors": ["{color2}", "{color3}", "{color4}", "{color1}", "{color5}", "{color6}"],
    "background": true
  }
}
EOF


# Aplica wallpaper
desktop-session-wallpaper &

# Gera cores com Pywal
wal -i "$IMAGE" -n -e

# Força a regeneração dos templates
wal -R

# Aplica os temas gerados
cp ~/.cache/wal/colors-polybar ~/.config/polybar/colors.ini
cp ~/.cache/wal/colors-rofi ~/.config/rofi/colors/black.rasi
cp ~/.cache/wal/colors-dunst ~/.config/dunst/dunstrc
cp ~/.cache/wal/colors-kitty ~/.config/kitty/current-theme.conf
cp ~/.cache/wal/colors-htop ~/.config/htop/pywal.theme
cp ~/.cache/wal/colors-btop ~/.config/btop/themes/pywal.theme
cp ~/.cache/wal/colors-icewm ~/.icewm/themes/Default/default.theme

icewm --restart 2>/dev/null || icewmtray --restart 2>/dev/null

pkill -USR2 btop 2>/dev/null || true
pkill polybar 2>/dev/null
polybar kaay &
killall dunst 2>/dev/null; dunst &